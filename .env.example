APP_NAME="Casuya Platform"
ENVIRONMENT=development
DEBUG=true

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/casuya_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# Casuya Core Signing
CASUYA_CORE_SIGNING_KEY=
CASUYA_BRIDGE_SHARED_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Cloudflare
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# AzamPay
AZAMPAY_CLIENT_ID=
AZAMPAY_CLIENT_SECRET=
AZAMPAY_APP_NAME=
AZAMPAY_X_API_KEY=
AZAMPAY_SANDBOX=true

# Africa's Talking
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=

# Storage
STORAGE_ROOT=./storage

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120
