{
  "name": "casuya-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Student/admin/teacher platform for Casuya (casuya.co.tz)",
  "scripts": {
    "dev:backend": "uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npx serve frontend -l 5173",
    "seed": "python -m database.seeds.seed_dev_data",
    "create-admin": "python -m database.seeds.create_admin",
    "test": "pytest tests/ -v",
    "test:coverage": "pytest tests/ --cov=backend --cov=integrations -v",
    "build": "echo 'Frontend is static HTML/JS — no build step required'",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "serve": "^14.2.0"
  }
}
